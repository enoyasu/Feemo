{
  "name": "feemo-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply feemo-db",
    "db:migrate:local": "wrangler d1 migrations apply feemo-db --local",
    "db:seed:local": "wrangler d1 execute feemo-db --local --file=migrations/seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250430.0",
    "wrangler": "^3.114.0"
  }
}
